{
  "name": "package-vision",
  "displayName": "Package Vision",
  "description": "Inspect workspace dependency declarations from the VS Code sidebar.",
  "version": "0.0.1",
  "publisher": "zongpengz",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "package.json",
    "dependencies",
    "npm",
    "versions"
  ],
  "activationEvents": [
    "onView:packageVision.dependencies",
    "onCommand:packageVision.refresh",
    "onCommand:packageVision.setFilter",
    "onCommand:packageVision.clearFilter",
    "onCommand:packageVision.openPackageJson",
    "onCommand:packageVision.upgradeDependency",
    "onCommand:packageVision.showOutput"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "packageVision",
          "title": "Package Vision",
          "icon": "resources/package-vision.svg"
        }
      ]
    },
    "views": {
      "packageVision": [
        {
          "id": "packageVision.dependencies",
          "name": "Dependencies"
        }
      ]
    },
    "commands": [
      {
        "command": "packageVision.refresh",
        "title": "Refresh Dependencies",
        "icon": "$(refresh)"
      },
      {
        "command": "packageVision.openPackageJson",
        "title": "Open package.json",
        "icon": "$(go-to-file)"
      },
      {
        "command": "packageVision.upgradeDependency",
        "title": "Upgrade Dependency to Latest",
        "icon": {
          "light": "resources/upgrade-light.svg",
          "dark": "resources/upgrade-dark.svg"
        }
      },
      {
        "command": "packageVision.showOutput",
        "title": "Show Package Vision Output",
        "icon": "$(output)"
      },
      {
        "command": "packageVision.setFilter",
        "title": "Filter Dependencies",
        "icon": "$(filter)"
      },
      {
        "command": "packageVision.clearFilter",
        "title": "Clear Dependency Filter",
        "icon": "$(close)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "packageVision.refresh",
          "when": "view == packageVision.dependencies",
          "group": "navigation"
        },
        {
          "command": "packageVision.openPackageJson",
          "when": "view == packageVision.dependencies",
          "group": "navigation"
        },
        {
          "command": "packageVision.showOutput",
          "when": "view == packageVision.dependencies",
          "group": "navigation"
        },
        {
          "command": "packageVision.setFilter",
          "when": "view == packageVision.dependencies",
          "group": "navigation"
        },
        {
          "command": "packageVision.clearFilter",
          "when": "view == packageVision.dependencies && packageVision.hasActiveFilter",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "packageVision.upgradeDependency",
          "when": "view == packageVision.dependencies && viewItem == dependencyOutdated",
          "group": "inline"
        },
        {
          "command": "packageVision.upgradeDependency",
          "when": "view == packageVision.dependencies && viewItem == dependencyOutdated",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Package Vision",
      "properties": {
        "packageVision.upgrade.versionRangeStyle": {
          "type": "string",
          "default": "preserve",
          "scope": "resource",
          "enum": [
            "preserve",
            "caret",
            "tilde",
            "exact"
          ],
          "enumDescriptions": [
            "Keep the current dependency style when possible, such as ^, ~, or exact.",
            "Always save upgraded dependencies with a ^ prefix.",
            "Always save upgraded dependencies with a ~ prefix.",
            "Always save upgraded dependencies as an exact version."
          ],
          "markdownDescription": "Controls how Package Vision writes upgraded dependency ranges back to `package.json`."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc --watch -p ./",
    "test": "npm run test:unit",
    "test:unit": "tsx --test tests/**/*.test.ts",
    "pretest:integration": "npm run compile",
    "test:integration": "node ./out/test/runTest.js",
    "check": "npm run compile && npm run test:unit",
    "check:full": "npm run check && npm run test:integration"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.6.0",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.105.0",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.7.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "semver": "^7.7.4"
  }
}
